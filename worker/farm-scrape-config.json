{
  "_doc": "Per-farm scraper config. Each entry maps farm_id → URL + DOM selectors. The 'stallion_card' selector identifies each stallion's containing element on the page; the others are queried RELATIVE to each card. Use --dry-run to validate selectors before writing CSV. To inspect a page's DOM, open it in browser dev tools and find the repeating block (often <article>, <div class='stallion-card'>, etc.) — that's your stallion_card. The selectors below are educated starting points; real-world DOMs vary, so tune them per farm using View Source.",
  "farms": {
    "pinoak": {
      "name":    "Pin Oak Stud",
      "url":     "https://www.pinoakstud.com/stallions",
      "enabled": true,
      "selectors": {
        "stallion_card":     ".stallion-card, article.stallion, .stallions__item",
        "name":              "h2, h3, .stallion-name",
        "pedigree":          ".pedigree, .stallion-pedigree, em",
        "fee":               ".fee, .stud-fee, .stallions__fee"
      }
    },
    "millridge": {
      "name":    "Mill Ridge Farm",
      "url":     "https://www.millridge.com/stallions/",
      "enabled": true,
      "selectors": {
        "stallion_card":     "article, .stallion, .post",
        "name":              "h2 a, h3, .entry-title",
        "pedigree":          ".pedigree, em, p:first-of-type",
        "fee":               ".fee, .price, .stud-fee"
      }
    },
    "crestwood": {
      "name":    "Crestwood Farm",
      "url":     "https://www.crestwoodfarm.com/stallions/",
      "enabled": true,
      "selectors": {
